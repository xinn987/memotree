APP_ENV=staging
PUBLIC_BASE_URL=https://example.com

MYSQL_DATABASE=memotree
MYSQL_USER=memotree
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
MYSQL_DSN=memotree:change-me@tcp(mysql:3306)/memotree?parseTime=true

SESSION_COOKIE_NAME=memotree_session
SESSION_TTL_HOURS=720

STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=change-me
STORAGE_SECRET_ACCESS_KEY=change-me
STORAGE_USE_PATH_STYLE=false
STORAGE_BUCKET_ORIGINALS=memotree-originals-staging
STORAGE_BUCKET_PREVIEWS=memotree-previews-staging

SIGNED_URL_TTL_SECONDS=900
UPLOAD_MAX_FILE_BYTES=52428800
UPLOAD_MAX_BATCH_COUNT=20

MEDIA_WORKER_CONCURRENCY=1
MEDIA_WORKER_POLL_INTERVAL_SECONDS=5
