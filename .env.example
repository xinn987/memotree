APP_ENV=local
API_ADDR=:8080
SESSION_COOKIE_NAME=memotree_session
SESSION_TTL_HOURS=720

# 本地 Docker MySQL：
# docker compose -f deploy/docker-compose.dev.yml up -d mysql
MYSQL_DSN=memotree:memotree@tcp(127.0.0.1:3307)/memotree?parseTime=true

# 本地 Docker MinIO：
# docker compose -f deploy/docker-compose.dev.yml up -d minio
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=memotree
STORAGE_SECRET_ACCESS_KEY=memotree-secret
STORAGE_USE_PATH_STYLE=true
STORAGE_BUCKET_ORIGINALS=memotree-originals
STORAGE_BUCKET_PREVIEWS=memotree-previews
